# Add your Gemini AI API Key here, then rename this file to .env
GEMINI_API_KEY=
PORT=5000

# FastAPI LLM Service URL (Kisaan Mitra AI)
# Default: local development. For production, set this to your deployed FastAPI URL.
# Example: LLM_SERVICE_URL=https://your-kisaan-llm-service.onrender.com
LLM_SERVICE_URL=http://localhost:8000
